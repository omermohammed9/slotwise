# local, staging, production, or test. Production fails fast on unsafe settings.
SLOTWISE_ENV=local
PORT=3000
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/booking-system

# Comma-separated browser origins. Production origins must be explicit https:// URLs.
SLOTWISE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SLOTWISE_TRUST_PROXY=false

# Cookie-session auth. Production always requires Secure cookies.
SLOTWISE_SESSION_COOKIE_NAME=slotwise_session
SLOTWISE_CSRF_COOKIE_NAME=slotwise_csrf
SLOTWISE_SESSION_COOKIE_SECURE=false
SLOTWISE_SESSION_TTL_MINUTES=480
SLOTWISE_AUTH_PEPPER=replace_with_strong_random_pepper

# Local/test-only operator bootstrap for disposable development databases.
# Production rejects SLOTWISE_OWNER_*, SLOTWISE_ADMIN_*, and SLOTWISE_STAFF_* credentials.
# Use the controlled first-owner setup path for production, then owner invitations.
# SLOTWISE_OWNER_USERNAME=owner
# SLOTWISE_OWNER_PASSWORD=replace_with_owner_password
# SLOTWISE_OWNER_ACTOR_ID=owner-1

# One-time first owner setup command inputs. Do not leave these set after running.
# SLOTWISE_SETUP_OWNER_USERNAME=owner@example.com
# SLOTWISE_SETUP_OWNER_PASSWORD=replace_with_strong_owner_password

# Customer magic-link auth and notifications.
SLOTWISE_MAGIC_LINK_TTL_MINUTES=15
SLOTWISE_EMAIL_PROVIDER=noop
SLOTWISE_EMAIL_FROM=no-reply@example.com
RESEND_API_KEY=replace_with_resend_api_key
SLOTWISE_CUSTOMER_MAGIC_LINK_BASE_URL=https://example.com/customer-auth
SLOTWISE_OPERATOR_INVITATION_BASE_URL=https://example.com/operators/invitations/accept
SLOTWISE_OPERATOR_PASSWORD_RESET_BASE_URL=https://example.com/operators/password-reset/complete
SLOTWISE_NOTIFICATION_WORKER_ENABLED=true
SLOTWISE_NOTIFICATION_WORKER_INTERVAL_MS=15000
SLOTWISE_NOTIFICATION_WORKER_BATCH_SIZE=10
SLOTWISE_DNS_SERVERS=8.8.8.8,1.1.1.1

# Optional email verification integration used by existing validation flows.
HUNTER_API_KEY=your_hunter_api_key
